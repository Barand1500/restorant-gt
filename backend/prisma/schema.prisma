// Guzel Teknoloji — MASTER_DB (restoran-db)
// Sube kurulumu icin schema-sube.prisma kullanilir (DB_TURU=sube)
// Ek tablolar: ayarlar (panel), yedek_kaydi, kullanici_kisayol, kullanici_sekme_ayar,
// eklenti_katalog, eklenti_kurulum, bildirim

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum YedeklemeFormati {
  json
  sql
  rar
  zip
}

enum YedekIslemTipi {
  indir
  geri_yukle
}

enum BildirimTipi {
  sistem
}

enum EklentiDurum {
  kurulu
  aktif
  pasif
}

enum EklentiKaynak {
  katalog
  yukleme
}

enum KullaniciTipi {
  merkez
  bayi
  firma
  sube
}

enum SubeTipi {
  restoran
  kafe
  fast_food
  diger
}

// ---------------------------------------------------------------------------
// MASTER_DB
// ---------------------------------------------------------------------------

model Modul {
  id               Int      @id @default(autoincrement())
  modulAdi         String   @map("modul_adi") @db.VarChar(100)
  prefix           String   @unique @db.VarChar(50)
  kayitTarihi      DateTime @default(now()) @map("kayit_tarihi")
  guncellemeTarihi DateTime @updatedAt @map("guncelleme_tarihi")
  durum            Boolean  @default(true)

  roller Rol[]

  @@map("moduller")
}

model Rol {
  id               Int      @id @default(autoincrement())
  rolAdi           String   @map("rol_adi") @db.VarChar(50)
  modulId          Int      @map("modul_id")
  yetki            Json     @default("[]")
  kayitTarihi      DateTime @default(now()) @map("kayit_tarihi")
  guncellemeTarihi DateTime @updatedAt @map("guncelleme_tarihi")
  durum            Boolean  @default(true)

  modul        Modul       @relation(fields: [modulId], references: [id], onDelete: Cascade)
  kullanicilar Kullanici[]

  @@unique([modulId, rolAdi])
  @@index([rolAdi])
  @@map("roller")
}

model Bayi {
  id               Int      @id @default(autoincrement())
  ustId            Int?     @map("ust_id")
  unvan            String   @db.VarChar(191)
  adres            String?  @db.VarChar(500)
  il               String?  @db.VarChar(50)
  ilce             String?  @db.VarChar(50)
  telefon          String?  @db.VarChar(20)
  gsm              String?  @db.VarChar(20)
  eposta           String?  @db.VarChar(191)
  vergiDairesi     String?  @map("vergi_dairesi") @db.VarChar(100)
  vergiNo          String?  @map("vergi_no") @db.VarChar(50)
  iskonto          Decimal? @db.Decimal(5, 2)
  kayitTarihi      DateTime @default(now()) @map("kayit_tarihi")
  guncellemeTarihi DateTime @updatedAt @map("guncelleme_tarihi")
  durum            Boolean  @default(true)

  ustBayi      Bayi?       @relation("BayiHiyerarsi", fields: [ustId], references: [id], onDelete: SetNull)
  altBayiler   Bayi[]      @relation("BayiHiyerarsi")
  firmalar     Firma[]
  kullanicilar Kullanici[]

  @@index([ustId])
  @@map("bayiler")
}

model Firma {
  id               Int      @id @default(autoincrement())
  bayiId           Int      @map("bayi_id")
  tabelaAdi        String?  @map("tabela_adi") @db.VarChar(150)
  unvan            String   @db.VarChar(191)
  adres            String?  @db.VarChar(500)
  il               String?  @db.VarChar(50)
  ilce             String?  @db.VarChar(50)
  telefon          String?  @db.VarChar(20)
  gsm              String?  @db.VarChar(20)
  eposta           String?  @db.VarChar(191)
  vergiDairesi     String?  @map("vergi_dairesi") @db.VarChar(100)
  vergiNo          String?  @map("vergi_no") @db.VarChar(50)
  iskonto          Decimal? @db.Decimal(5, 2)
  kayitTarihi      DateTime @default(now()) @map("kayit_tarihi")
  guncellemeTarihi DateTime @updatedAt @map("guncelleme_tarihi")
  durum            Boolean  @default(true)

  bayi         Bayi        @relation(fields: [bayiId], references: [id], onDelete: Cascade)
  subeler      Sube[]
  lisanslar    Lisans[]
  kullanicilar Kullanici[]

  @@index([bayiId])
  @@map("firmalar")
}

model Sube {
  id               Int      @id @default(autoincrement())
  firmaId          Int      @map("firma_id")
  subeAdi          String   @map("sube_adi") @db.VarChar(100)
  adres            String?  @db.VarChar(500)
  il               String?  @db.VarChar(50)
  ilce             String?  @db.VarChar(50)
  telefon          String?  @db.VarChar(20)
  gsm              String?  @db.VarChar(20)
  eposta           String?  @db.VarChar(191)
  vergiDairesi     String?  @map("vergi_dairesi") @db.VarChar(100)
  vergiNo          String?  @map("vergi_no") @db.VarChar(50)
  subeTipi         SubeTipi @default(restoran) @map("sube_tipi")
  dbBilgileri      Json?    @map("db_bilgileri")
  lisansBilgileri  Json?    @map("lisans_bilgileri")
  iskonto          Decimal? @db.Decimal(5, 2)
  kayitTarihi      DateTime @default(now()) @map("kayit_tarihi")
  guncellemeTarihi DateTime @updatedAt @map("guncelleme_tarihi")
  durum            Boolean  @default(true)

  firma          Firma        @relation(fields: [firmaId], references: [id], onDelete: Cascade)
  kullanicilar   Kullanici[]
  bildirimler    Bildirim[]
  yedekKayitlari YedekKaydi[]

  @@index([firmaId])
  @@map("subeler")
}

model Paket {
  id               Int      @id @default(autoincrement())
  paketAdi         String   @map("paket_adi") @db.VarChar(100)
  subeSayisi       Int      @default(1) @map("sube_sayisi")
  personelSayisi   Int      @default(10) @map("personel_sayisi")
  masaSayisi       Int      @default(50) @map("masa_sayisi")
  fiyat            Decimal  @default(0) @db.Decimal(12, 2)
  paraBirimi       String   @default("TRY") @map("para_birimi") @db.VarChar(3)
  kayitTarihi      DateTime @default(now()) @map("kayit_tarihi")
  guncellemeTarihi DateTime @updatedAt @map("guncelleme_tarihi")
  durum            Boolean  @default(true)

  lisanslar Lisans[]

  @@map("paketler")
}

model Lisans {
  id               Int       @id @default(autoincrement())
  firmaId          Int       @map("firma_id")
  paketId          Int       @map("paket_id")
  baslangicTarihi  DateTime  @default(now()) @map("baslangic_tarihi")
  bitisTarihi      DateTime? @map("bitis_tarihi")
  kayitTarihi      DateTime  @default(now()) @map("kayit_tarihi")
  guncellemeTarihi DateTime  @updatedAt @map("guncelleme")
  durum            Boolean   @default(true)

  firma Firma @relation(fields: [firmaId], references: [id], onDelete: Cascade)
  paket Paket @relation(fields: [paketId], references: [id], onDelete: Restrict)

  @@index([firmaId])
  @@index([paketId])
  @@map("lisanslar")
}

model Kullanici {
  id             Int           @id @default(autoincrement())
  rolId          Int           @map("rol_id")
  bayiId         Int?          @map("bayi_id")
  firmaId        Int?          @map("firma_id")
  subeId         Int?          @map("sube_id")
  ad             String        @map("ad_soyad") @db.VarChar(150)
  gsm            String?       @db.VarChar(20)
  email          String        @unique @map("eposta") @db.VarChar(191)
  sifreHash      String        @map("sifre_hash") @db.VarChar(255)
  kullaniciTipi  KullaniciTipi @default(merkez) @map("kullanici_tipi")
  iskonto        Decimal?      @db.Decimal(5, 2)
  sonGirisTarihi DateTime?     @map("son_giris_tarihi")
  aktif          Boolean       @default(true) @map("durum")
  olusturma      DateTime      @default(now()) @map("kayit_tarihi")
  guncelleme     DateTime      @updatedAt @map("guncelleme_tarihi")

  rol            Rol                 @relation(fields: [rolId], references: [id], onDelete: Restrict)
  bayi           Bayi?               @relation(fields: [bayiId], references: [id], onDelete: SetNull)
  firma          Firma?              @relation(fields: [firmaId], references: [id], onDelete: SetNull)
  sube           Sube?               @relation(fields: [subeId], references: [id], onDelete: SetNull)
  kisayolAyari   KullaniciKisayol?
  sekmeAyari     KullaniciSekmeAyar?
  loglar         Log[]
  yedekKayitlari YedekKaydi[]

  @@index([rolId])
  @@index([bayiId])
  @@index([firmaId])
  @@index([subeId])
  @@map("kullanicilar")
}

model Log {
  id          Int      @id @default(autoincrement())
  kullaniciId Int?     @map("kullanici_id")
  logTipi     String?  @map("log_tipi") @db.VarChar(30)
  mesaj       String   @db.VarChar(1000)
  ipAdresi    String?  @map("ip_adresi") @db.VarChar(45)
  kayitTarihi DateTime @default(now()) @map("kayit_tarihi")

  kullanici Kullanici? @relation(fields: [kullaniciId], references: [id], onDelete: SetNull)

  @@index([kayitTarihi])
  @@map("log")
}

// ---------------------------------------------------------------------------
// Panel ayarlari (resimde yok — sistem ayarlari icin)
// ---------------------------------------------------------------------------

model Ayar {
  id               Int      @id @default(autoincrement())
  subeId           Int      @default(0) @map("sube_id")
  anahtar          String   @db.VarChar(100)
  deger            Json
  kayitTarihi      DateTime @default(now()) @map("kayit_tarihi")
  guncellemeTarihi DateTime @updatedAt @map("guncelleme_tarihi")

  @@unique([subeId, anahtar])
  @@index([anahtar])
  @@map("ayarlar")
}

// ---------------------------------------------------------------------------
// Dokunulmayan tablolar (kullanici istegi)
// ---------------------------------------------------------------------------

model KullaniciKisayol {
  kullaniciId Int  @id @map("kullanici_id")
  harita      Json @default("{}")

  kullanici Kullanici @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)

  @@map("kullanici_kisayol")
}

model KullaniciSekmeAyar {
  kullaniciId Int  @id @map("kullanici_id")
  ayarlar     Json @default("{}")

  kullanici Kullanici @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)

  @@map("kullanici_sekme_ayar")
}

model EklentiKatalog {
  kod           String   @id @db.VarChar(100)
  ad            String   @db.VarChar(150)
  aciklama      String   @db.VarChar(1000)
  gelistirici   String   @db.VarChar(100)
  ikon          String   @db.VarChar(50)
  kategori      String   @db.VarChar(50)
  surum         String   @db.VarChar(30)
  puan          Float    @default(0)
  etkinKurulum  Int      @default(0) @map("etkin_kurulum")
  sonGuncelleme DateTime @default(now()) @map("son_guncelleme")
  publicHook    String?  @map("public_hook") @db.VarChar(100)
  manifestJson  Json?    @map("manifest_json")

  kurulumlar EklentiKurulum[]

  @@map("eklenti_katalog")
}

model EklentiKurulum {
  id            Int           @id @default(autoincrement())
  subeId        Int           @default(0) @map("sube_id")
  eklentiKodu   String        @map("eklenti_kodu") @db.VarChar(100)
  durum         EklentiDurum  @default(kurulu)
  kaynak        EklentiKaynak @default(katalog)
  ayarlarJson   Json          @default("{}") @map("ayarlar_json")
  kurulumTarihi DateTime      @default(now()) @map("kurulum_tarihi")
  guncelleme    DateTime      @updatedAt @map("guncelleme")

  eklenti EklentiKatalog @relation(fields: [eklentiKodu], references: [kod], onDelete: Cascade)

  @@unique([subeId, eklentiKodu])
  @@map("eklenti_kurulum")
}

model YedekKaydi {
  id             Int              @id @default(autoincrement())
  subeId         Int?             @map("sube_id")
  kullaniciId    Int?             @map("kullanici_id")
  kullaniciAd    String           @map("kullanici_ad") @db.VarChar(150)
  kullaniciEmail String           @map("kullanici_email") @db.VarChar(191)
  dosyaAdi       String           @map("dosya_adi") @db.VarChar(255)
  tip            YedekIslemTipi
  format         YedeklemeFormati @default(json)
  olusturma      DateTime         @default(now()) @map("kayit_tarihi")

  sube      Sube?      @relation(fields: [subeId], references: [id], onDelete: SetNull)
  kullanici Kullanici? @relation(fields: [kullaniciId], references: [id], onDelete: SetNull)

  @@index([olusturma])
  @@map("yedek_kaydi")
}

model Bildirim {
  id        Int          @id @default(autoincrement())
  subeId    Int?         @map("sube_id")
  tip       BildirimTipi
  baslik    String       @db.VarChar(150)
  mesaj     String       @db.VarChar(1000)
  okundu    Boolean      @default(false)
  link      String?      @db.VarChar(500)
  olusturma DateTime     @default(now()) @map("kayit_tarihi")

  sube Sube? @relation(fields: [subeId], references: [id], onDelete: Cascade)

  @@index([okundu, olusturma])
  @@map("bildirim")
}
