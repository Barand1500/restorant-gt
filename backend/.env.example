# CloudPanel — restoran.guzelteknoloji.com (SUBE kurulumu)
# DB_TURU=sube  -> schema-sube.prisma + sube1-db
# DB_TURU=master -> schema.prisma + restoran-db (ileride master panel)

DB_TURU=sube

# Sube veritabani (sube1-db / sube1-user)
# Ozel karakterli sifre (! @ # vb.) icin URL kodlayin: ! -> %21
DATABASE_URL="mysql://sube1-user:SIFRENIZ@127.0.0.1:3306/sube1-db"

PORT=3006
NODE_ENV=production

JWT_SECRET=buraya-uzun-rastgele-anahtar-yazin-min-32-karakter

CORS_ORIGIN=https://restoran.guzelteknoloji.com

# Opsiyonel — seed admin (bos birakilirsa varsayilan kullanilir)
# SEED_ADMIN_EMAIL=admin@restorant.local
# SEED_ADMIN_PASSWORD=admin123
