{
  "name": "restorant-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Restorant GT — admin API (Express + Prisma + MySQL)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node ./node_modules/typescript/bin/tsc",
    "start": "node dist/index.js",
    "setup": "bash scripts/db-push-safe.sh",
    "db:generate": "node scripts/prisma-generate.mjs",
    "db:push": "bash scripts/db-push-safe.sh",
    "db:push:master": "DB_TURU=master bash scripts/db-push-safe.sh",
    "db:reset": "DB_RESET=1 bash scripts/db-push-safe.sh",
    "db:migrate": "node ./node_modules/prisma/build/index.js migrate deploy",
    "db:seed": "node prisma/seed.mjs",
    "db:seed:sube": "node prisma/seed-sube.mjs",
    "db:studio": "node ./node_modules/prisma/build/index.js studio",
    "postinstall": "node scripts/prisma-generate.mjs"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "prisma": "^6.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.19.1",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
