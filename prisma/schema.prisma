// Restorant GT — MySQL veritabani semasi
// Tablo ve alan adlari: Turkce mantik, ASCII karakter (i,s,g,u,o,c; alt tire)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Sabit listeler (enum)
// ---------------------------------------------------------------------------

enum YedeklemeFormati {
  json
  sql
  rar
  zip
}

enum YedekIslemTipi {
  indir
  geri_yukle
}

enum BildirimTipi {
  form_gonderim
  sistem
}

enum SayfaAcilisModu {
  normal
  yeni_sekme
  modal
}

enum AltMenuGorunum {
  dikey
  yatay
}

enum AltMenuTetikleyici {
  hover
  tikla
}

enum EklentiDurum {
  kurulu
  aktif
  pasif
}

enum EklentiKaynak {
  katalog
  yukleme
}

enum FormGonderimDurum {
  yeni
  okundu
  arsivlendi
}

// ---------------------------------------------------------------------------
// Coklu site / tenant
// ---------------------------------------------------------------------------

model Site {
  id         String   @id @default(cuid()) @db.VarChar(30)
  ad         String   @db.VarChar(191)
  slug       String   @unique @db.VarChar(100)
  domain     String?  @db.VarChar(255)
  aktif      Boolean  @default(true)
  olusturma  DateTime @default(now()) @map("olusturma")
  guncelleme DateTime @updatedAt @map("guncelleme")

  ayar           SiteAyar?
  kullanicilar   Kullanici[]
  roller         Rol[]
  sayfalar       Sayfa[]
  widgetlar      Widget[]
  islemLoglari   IslemLogu[]
  yedekKayitlari YedekKaydi[]
  bildirimler    Bildirim[]
  siteEklentiler SiteEklenti[]
  blogYazilari   BlogYazi[]
  formTanimlari  FormTanimi[]
  medyaDosyalari MedyaDosyasi[]

  @@map("site")
}

model SiteAyar {
  siteId String @id @map("site_id") @db.VarChar(30)
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  // Bakim modu
  bakimModu           Boolean @default(false) @map("bakim_modu")
  bakimBaslik         String  @default("Bakim Calismasi") @map("bakim_baslik") @db.VarChar(191)
  bakimMesaji         String  @default("Site gecici olarak bakimda.") @map("bakim_mesaji") @db.VarChar(1000)
  bakimGorselUrl      String? @map("bakim_gorsel_url") @db.VarChar(500)
  bakimTahminiSure    String? @map("bakim_tahmini_sure") @db.VarChar(100)
  bakimIpBeyazListe   Json    @default("[]") @map("bakim_ip_beyaz_liste")

  // Panel ve log
  logSaklamaGun Int    @default(90) @map("log_saklama_gun")
  panelDili     String @default("tr") @map("panel_dili") @db.VarChar(10)
  panelCeviriler Json  @default("{}") @map("panel_ceviriler")

  // 404 sayfasi (JSON — Sayfa404Ayarlari)
  sayfa404 Json @default("{}") @map("sayfa_404")

  // Yedekleme
  otomatikYedekleme    Boolean            @default(false) @map("otomatik_yedekleme")
  otomatikYedeklemeGun Int                @default(7) @map("otomatik_yedekleme_gun")
  yedeklemeFormati     YedeklemeFormati   @default(json) @map("yedekleme_formati")

  // Guvenlik
  guvenlikBasliklari Boolean @default(true) @map("guvenlik_basliklari")
  robotsEngelle      Boolean @default(false) @map("robots_engelle")

  // Sag tik paneli ve scriptler (JSON)
  sagTikPaneli   Json @default("{}") @map("sag_tik_paneli")
  scriptAyarlari Json @default("{}") @map("script_ayarlari")

  guncelleme DateTime @updatedAt @map("guncelleme")

  @@map("site_ayar")
}

// ---------------------------------------------------------------------------
// Kimlik ve yetkilendirme
// ---------------------------------------------------------------------------

model Kullanici {
  id         String   @id @default(cuid()) @db.VarChar(30)
  siteId     String?  @map("site_id") @db.VarChar(30)
  email      String   @unique @db.VarChar(191)
  ad         String   @db.VarChar(191)
  sifreHash  String   @map("sifre_hash") @db.VarChar(255)
  pinHash    String?  @map("pin_hash") @db.VarChar(255)
  rolKodu    String   @map("rol_kodu") @db.VarChar(50)
  aktif      Boolean  @default(true)
  olusturma  DateTime @default(now()) @map("olusturma")
  guncelleme DateTime @updatedAt @map("guncelleme")

  site           Site?            @relation(fields: [siteId], references: [id], onDelete: SetNull)
  tercih         KullaniciTercih?
  kisayolAyari   KullaniciKisayol?
  islemLoglari   IslemLogu[]
  yedekKayitlari YedekKaydi[]

  @@index([siteId])
  @@index([rolKodu])
  @@map("kullanici")
}

model KullaniciTercih {
  kullaniciId           String @id @map("kullanici_id") @db.VarChar(30)
  dashboardHizliErisim   Json   @default("[]") @map("dashboard_hizli_erisim")

  kullanici Kullanici @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)

  @@map("kullanici_tercih")
}

model KullaniciKisayol {
  kullaniciId String @id @map("kullanici_id") @db.VarChar(30)
  harita      Json   @default("{}")

  kullanici Kullanici @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)

  @@map("kullanici_kisayol")
}

model Rol {
  id         String   @id @default(cuid()) @db.VarChar(30)
  siteId     String?  @map("site_id") @db.VarChar(30)
  kod        String   @db.VarChar(50)
  baslik     String   @db.VarChar(191)
  aciklama   String   @default("") @db.VarChar(500)
  sistemRolu Boolean  @default(false) @map("sistem_rolu")
  olusturma  DateTime @default(now()) @map("olusturma")
  guncelleme DateTime @updatedAt @map("guncelleme")

  site    Site?      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  yetkiler RolYetki[]

  @@unique([siteId, kod])
  @@map("rol")
}

model Yetki {
  kod    String @id @db.VarChar(50)
  etiket String @db.VarChar(191)

  roller RolYetki[]

  @@map("yetki")
}

model RolYetki {
  rolId     String @map("rol_id") @db.VarChar(30)
  yetkiKodu String @map("yetki_kodu") @db.VarChar(50)

  rol    Rol    @relation(fields: [rolId], references: [id], onDelete: Cascade)
  yetki  Yetki  @relation(fields: [yetkiKodu], references: [kod], onDelete: Cascade)

  @@id([rolId, yetkiKodu])
  @@map("rol_yetki")
}

// ---------------------------------------------------------------------------
// Icerik yonetimi
// ---------------------------------------------------------------------------

model Sayfa {
  id                 String              @id @default(cuid()) @db.VarChar(30)
  siteId             String              @map("site_id") @db.VarChar(30)
  baslik             String              @db.VarChar(191)
  slug               String              @db.VarChar(191)
  icerik             String              @db.LongText
  kapakGorsel        String?             @map("kapak_gorsel") @db.VarChar(500)
  ikon               String?             @db.VarChar(50)
  seoTitle           String?             @map("seo_title") @db.VarChar(191)
  seoDesc            String?             @map("seo_desc") @db.VarChar(500)
  yayinda            Boolean             @default(false)
  menudeGoster       Boolean             @default(true) @map("menude_goster")
  sira               Int                 @default(0)
  acilisModu         SayfaAcilisModu     @default(normal) @map("acilis_modu")
  ustSayfaId         String?             @map("ust_sayfa_id") @db.VarChar(30)
  altMenuGorunum     AltMenuGorunum      @default(dikey) @map("alt_menu_gorunum")
  altMenuTetikleyici AltMenuTetikleyici  @default(hover) @map("alt_menu_tetikleyici")
  olusturma          DateTime            @default(now()) @map("olusturma")
  guncelleme         DateTime            @updatedAt @map("guncelleme")

  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  ustSayfa  Sayfa?   @relation("SayfaHiyerarsi", fields: [ustSayfaId], references: [id], onDelete: SetNull)
  altSayfalar Sayfa[] @relation("SayfaHiyerarsi")
  widgetlar Widget[]

  @@unique([siteId, slug])
  @@index([siteId, sira])
  @@index([ustSayfaId])
  @@map("sayfa")
}

model Widget {
  id              String   @id @default(cuid()) @db.VarChar(30)
  siteId          String   @map("site_id") @db.VarChar(30)
  sayfaId         String?  @map("sayfa_id") @db.VarChar(30)
  ad              String   @db.VarChar(191)
  tip             String   @db.VarChar(50)
  sira            Int      @default(0)
  aktif           Boolean  @default(true)
  baslik          String?  @db.VarChar(191)
  altBaslik       String?  @map("alt_baslik") @db.VarChar(191)
  aciklama        String?  @db.Text
  gorselUrl       String?  @map("gorsel_url") @db.VarChar(500)
  butonMetni      String?  @map("buton_metni") @db.VarChar(100)
  butonLink       String?  @map("buton_link") @db.VarChar(500)
  arkaPlanRenk    String?  @map("arka_plan_renk") @db.VarChar(20)
  yaziRenk        String?  @map("yazi_renk") @db.VarChar(20)
  mobilGoster     Boolean  @default(true) @map("mobil_goster")
  masaustuGoster  Boolean  @default(true) @map("masaustu_goster")
  configJson      Json?    @map("config_json")
  olusturma       DateTime @default(now()) @map("olusturma")
  guncelleme      DateTime @updatedAt @map("guncelleme")

  site  Site  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  sayfa Sayfa? @relation(fields: [sayfaId], references: [id], onDelete: SetNull)

  @@index([siteId, sayfaId, sira])
  @@map("widget")
}

model BlogYazi {
  id          String   @id @default(cuid()) @db.VarChar(30)
  siteId      String   @map("site_id") @db.VarChar(30)
  baslik      String   @db.VarChar(191)
  slug        String   @db.VarChar(191)
  ozet        String?  @db.Text
  icerik      String   @db.LongText
  kapakGorsel String?  @map("kapak_gorsel") @db.VarChar(500)
  yazarAd     String?  @map("yazar_ad") @db.VarChar(191)
  yayinda     Boolean  @default(false)
  yayinTarihi DateTime? @map("yayin_tarihi")
  seoTitle    String?  @map("seo_title") @db.VarChar(191)
  seoDesc     String?  @map("seo_desc") @db.VarChar(500)
  olusturma   DateTime @default(now()) @map("olusturma")
  guncelleme  DateTime @updatedAt @map("guncelleme")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, slug])
  @@index([siteId, yayinda])
  @@map("blog_yazi")
}

model MedyaDosyasi {
  id         String   @id @default(cuid()) @db.VarChar(30)
  siteId     String   @map("site_id") @db.VarChar(30)
  dosyaAdi   String   @map("dosya_adi") @db.VarChar(255)
  orijinalAd String   @map("orijinal_ad") @db.VarChar(255)
  mimeTip    String   @map("mime_tip") @db.VarChar(100)
  boyut      Int      @default(0)
  genislik   Int?
  yukseklik  Int?
  url        String   @db.VarChar(500)
  altMetin   String?  @map("alt_metin") @db.VarChar(255)
  olusturma  DateTime @default(now()) @map("olusturma")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, olusturma])
  @@map("medya_dosyasi")
}

// ---------------------------------------------------------------------------
// Formlar
// ---------------------------------------------------------------------------

model FormTanimi {
  id                    String   @id @default(cuid()) @db.VarChar(30)
  siteId                String   @map("site_id") @db.VarChar(30)
  ad                    String   @db.VarChar(191)
  slug                  String   @db.VarChar(100)
  alanlarJson           Json     @default("[]") @map("alanlar_json")
  aktif                 Boolean  @default(true)
  kullaniciyaOtomatikYanit Boolean @default(false) @map("kullaniciya_otomatik_yanit")
  olusturma             DateTime @default(now()) @map("olusturma")
  guncelleme            DateTime @updatedAt @map("guncelleme")

  site       Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  gonderimler FormGonderim[]

  @@unique([siteId, slug])
  @@map("form_tanimi")
}

model FormGonderim {
  id         String            @id @default(cuid()) @db.VarChar(30)
  formId     String            @map("form_id") @db.VarChar(30)
  veriJson   Json              @map("veri_json")
  durum      FormGonderimDurum @default(yeni)
  ipAdresi   String?           @map("ip_adresi") @db.VarChar(45)
  olusturma  DateTime          @default(now()) @map("olusturma")

  form FormTanimi @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId, olusturma])
  @@map("form_gonderim")
}

// ---------------------------------------------------------------------------
// Eklentiler
// ---------------------------------------------------------------------------

model EklentiKatalog {
  kod            String   @id @db.VarChar(100)
  ad             String   @db.VarChar(191)
  aciklama       String   @db.Text
  gelistirici    String   @db.VarChar(191)
  ikon           String   @db.VarChar(50)
  kategori       String   @db.VarChar(50)
  surum          String   @db.VarChar(30)
  puan           Float    @default(0)
  etkinKurulum   Int      @default(0) @map("etkin_kurulum")
  sonGuncelleme  DateTime @default(now()) @map("son_guncelleme")
  publicHook     String?  @map("public_hook") @db.VarChar(100)
  manifestJson   Json?    @map("manifest_json")

  siteKurulumlari SiteEklenti[]

  @@map("eklenti_katalog")
}

model SiteEklenti {
  id           String        @id @default(cuid()) @db.VarChar(30)
  siteId       String        @map("site_id") @db.VarChar(30)
  eklentiKodu  String        @map("eklenti_kodu") @db.VarChar(100)
  durum        EklentiDurum  @default(kurulu)
  kaynak       EklentiKaynak @default(katalog)
  ayarlarJson  Json          @default("{}") @map("ayarlar_json")
  kurulumTarihi DateTime     @default(now()) @map("kurulum_tarihi")
  guncelleme   DateTime      @updatedAt @map("guncelleme")

  site    Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  eklenti EklentiKatalog @relation(fields: [eklentiKodu], references: [kod], onDelete: Cascade)

  @@unique([siteId, eklentiKodu])
  @@map("site_eklenti")
}

// ---------------------------------------------------------------------------
// Sistem kayitlari
// ---------------------------------------------------------------------------

model IslemLogu {
  id            String   @id @default(cuid()) @db.VarChar(30)
  siteId        String   @map("site_id") @db.VarChar(30)
  kullaniciId   String?  @map("kullanici_id") @db.VarChar(30)
  kullaniciAd   String   @map("kullanici_ad") @db.VarChar(191)
  kullaniciEmail String  @map("kullanici_email") @db.VarChar(191)
  islem         String   @db.VarChar(500)
  modulId       String?  @map("modul_id") @db.VarChar(50)
  aksiyonId     String?  @map("aksiyon_id") @db.VarChar(50)
  olusturma     DateTime @default(now()) @map("olusturma")

  site      Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  kullanici Kullanici? @relation(fields: [kullaniciId], references: [id], onDelete: SetNull)

  @@index([siteId, olusturma])
  @@map("islem_logu")
}

model YedekKaydi {
  id             String         @id @default(cuid()) @db.VarChar(30)
  siteId         String         @map("site_id") @db.VarChar(30)
  kullaniciId    String?        @map("kullanici_id") @db.VarChar(30)
  kullaniciAd    String         @map("kullanici_ad") @db.VarChar(191)
  kullaniciEmail String         @map("kullanici_email") @db.VarChar(191)
  dosyaAdi       String         @map("dosya_adi") @db.VarChar(255)
  tip            YedekIslemTipi
  format         YedeklemeFormati @default(json)
  olusturma      DateTime       @default(now()) @map("olusturma")

  site      Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  kullanici Kullanici? @relation(fields: [kullaniciId], references: [id], onDelete: SetNull)

  @@index([siteId, olusturma])
  @@map("yedek_kaydi")
}

model Bildirim {
  id         String       @id @default(cuid()) @db.VarChar(30)
  siteId     String       @map("site_id") @db.VarChar(30)
  tip        BildirimTipi
  baslik     String       @db.VarChar(191)
  mesaj      String       @db.Text
  okundu     Boolean      @default(false)
  formId     String?      @map("form_id") @db.VarChar(30)
  gonderimId String?      @map("gonderim_id") @db.VarChar(30)
  link       String?      @db.VarChar(500)
  olusturma  DateTime     @default(now()) @map("olusturma")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, okundu, olusturma])
  @@map("bildirim")
}
